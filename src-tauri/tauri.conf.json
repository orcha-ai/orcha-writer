{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orcha Writer",
  "version": "0.1.1",
  "identifier": "com.orcha.writer",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Orcha Writer",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com; img-src 'self' data: asset: asset://localhost http://asset.localhost https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/**",
          "$HOME/.orcha-writer/**",
          "$HOME/**/.orcha-writer/**",
          "$TEMP/**"
        ]
      }
    },
    "macOSPrivateApi": true
  },
  "plugins": {
    "updater": {
      "endpoints": [],
      "pubkey": ""
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Orcha Writer",
    "longDescription": "跨平台 Markdown 写作与文档管理工具",
    "fileAssociations": [
      {
        "description": "Markdown Document",
        "ext": ["md", "markdown", "mdown", "mkd"],
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      }
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    }
  }
}
